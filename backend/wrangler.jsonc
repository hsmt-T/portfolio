{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "backend",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-15",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "portfolio",
			"database_id": "dcbd1e8e-d25b-4fd0-969f-89011280bf9d",
			"remote": true
		}
	],
	"r2_buckets": [
		{
			"bucket_name": "portfolio",
			"binding": "R2",
			"remote": true
		}
	]
}